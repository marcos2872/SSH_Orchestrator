{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ssh-orchestrator",
  "version": "0.0.1",
  "identifier": "com.marcos.ssh",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SSH Orchestrator",
        "width": 1024,
        "height": 680,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "languages": ["English", "PortugueseBrazilian"]
      }
    },
    "macOS": {
      "dmg": {}
    },
    "linux": {
      "deb": {},
      "rpm": {}
    }
  }
}
